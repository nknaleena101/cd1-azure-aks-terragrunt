# Local . tejnaform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

.terragrunt-cache
.terragrunt-cache/*
# Crash log files
crash.log
crash.*.log

#Exclude all .tfvars files, which are likely to contain sensitive data, such as
#password, private keys, and other secrets. These should not be part of version
#control as they are data points which are potentially sensitive and subjectit
#to change depending on the environment
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json